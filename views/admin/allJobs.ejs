<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>All Jobs</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
</head>
<body class="bg-gray-100 p-6">

    <div class="max-w-4xl mx-auto">
        <h1 class="text-3xl font-bold text-center text-gray-800">All Jobs</h1>

        <% if (currUser && currUser.role === 'admin') { %>
            <div class="text-center my-4">
                <a href="/add-job" class="bg-green-600 text-white px-4 py-2 rounded-lg hover:bg-green-700 transition">
                    ➕ Add New Job
                </a>
            </div>
        <% } %>

        <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6 mt-6 jobs-container opacity-0">
            <% jobs.forEach(job => { %>
                <div class="bg-white p-6 rounded-lg shadow-md transition transform hover:scale-105 job-card">
                    <h2 class="text-xl font-semibold text-gray-800"><%= job.title %></h2>
                    <p class="text-gray-600"><strong>Company:</strong> <%= job.company %></p>
                    <p class="text-gray-600"><strong>Location:</strong> <%= job.location %></p>
                    <p class="text-gray-500 text-sm mt-2"><%= job.description %></p>
                    <a href="/jobs/<%= job._id %>" class="mt-3 block text-green-600 hover:text-green-800 font-semibold">View Details →</a>

                    <% if (currUser && currUser.role === 'admin') { %>
                        <button class="mt-3 bg-red-500 text-white px-3 py-1 rounded-lg hover:bg-red-700 transition delete-btn"
                                onclick="deleteJob('<%= job._id %>')">
                            🗑️ Delete
                        </button>
                    <% } %>
                </div>
            <% }); %>
        </div>
    </div>

    <script>
        // Animate job cards appearance
        gsap.to(".jobs-container", { opacity: 1, duration: 1, ease: "power3.out" });

        async function deleteJob(id) {
            if (confirm('Are you sure you want to delete this job?')) {
                try {
                    await fetch(`/jobs/${id}`, { method: 'DELETE' });
                    location.reload();
                } catch (error) {
                    console.error("Error deleting job:", error);
                }
            }
        }
    </script>

</body>
</html>
