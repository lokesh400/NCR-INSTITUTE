<main class="mt-5 mb-32 min-h-screen flex flex-col">
    <div class="relative mb-6" data-aos="fade-right" data-aos-delay="100">
        <input type="text" placeholder="What course are you looking for?"
            class="w-full pl-12 pr-12 py-3 bg-white border border-gray-200 rounded-lg focus:outline-none focus:border-custom" />
        <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-gray-400"></i>
        <button class="absolute right-4 top-1/2 -translate-y-1/2 !rounded-button">
            <i class="fas fa-microphone text-custom"></i>
        </button>
    </div>
    <div class="flex gap-4 mb-8 overflow-x-auto py-2" data-aos="fade-right" data-aos-delay="100">
        <button
            class="flex-none px-6 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium hover:border-custom !rounded-button">
            <i class="fas fa-user-graduate mr-2 text-custom"></i>Admission
        </button>
        <a href="/jobs">
            <button
                class="flex-none px-6 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium hover:border-custom !rounded-button">
                <i class="fas fa-clock mr-2 text-custom"></i>Job Openings
            </button>
        </a>
        <a href="/facilities">
            <button
                class="flex-none px-6 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium hover:border-custom !rounded-button">
                <i class="fas fa-dollar-sign mr-2 text-custom"></i>Facilities
            </button>
        </a>
        <button
            class="flex-none px-6 py-2 bg-white border border-gray-200 rounded-lg text-sm font-medium hover:border-custom !rounded-button">
            <i class="fas fa-phone mr-2 text-custom"></i>Contact
        </button>
    </div>
    <div class="bg-custom rounded-xl p-6 text-white mb-8">
        <div class="flex items-start justify-between">
            <div>
                <h3 class="text-2xl font-bold mb-2">CNC & VMC Training Bootcamp</h3>
                <p class="text-green-100 mb-4">Technology &amp; Programming</p>
                <div class="flex items-center gap-4 mb-4">
                    <span class="flex items-center gap-2">
                        <i class="fas fa-clock"></i>
                        12 Weeks
                    </span>
                    <span class="flex items-center gap-2">
                        <i class="fas fa-tag"></i>
                        20% OFF
                    </span>
                </div>
                <button
                    class="bg-white text-custom px-6 py-2 rounded-lg font-medium hover:bg-gray-50 !rounded-button">
                    Enroll Now
                </button>
            </div>
            <img src="data:image/jpeg;base64,"
                alt="Web Development" class="w-32 h-32 object-contain" />
        </div>
    </div>
    <h2 class="text-xl font-bold mb-4">Course Categories</h2>
    <div class="grid grid-cols-5 gap-4 mb-8">
        <button
            class="flex flex-col items-center p-4 bg-white rounded-xl hover:shadow-md transition-shadow !rounded-button">
            <div class="w-12 h-12 bg-custom/10 rounded-full flex items-center justify-center mb-2">
                <i class="fas fa-laptop-code text-custom text-xl"></i>
            </div>
            <span class="text-sm font-medium">Industrial</span>
        </button>
        <button
            class="flex flex-col items-center p-4 bg-white rounded-xl hover:shadow-md transition-shadow !rounded-button">
            <div class="w-12 h-12 bg-custom/10 rounded-full flex items-center justify-center mb-2">
                <i class="fas fa-chart-line text-custom text-xl"></i>
            </div>
            <span class="text-sm font-medium">Regular Classroom</span>
        </button>
        <button
            class="flex flex-col items-center p-4 bg-white rounded-xl hover:shadow-md transition-shadow !rounded-button">
            <div class="w-12 h-12 bg-custom/10 rounded-full flex items-center justify-center mb-2">
                <i class="fas fa-palette text-custom text-xl"></i>
            </div>
            <span class="text-sm font-medium">Skill Development</span>
        </button>
        <button
            class="flex flex-col items-center p-4 bg-white rounded-xl hover:shadow-md transition-shadow !rounded-button">
            <div class="w-12 h-12 bg-custom/10 rounded-full flex items-center justify-center mb-2">
                <i class="fas fa-language text-custom text-xl"></i>
            </div>
            <span class="text-sm font-medium">Languages</span>
        </button>
        <button
            class="flex flex-col items-center p-4 bg-white rounded-xl hover:shadow-md transition-shadow !rounded-button">
            <div class="w-12 h-12 bg-custom/10 rounded-full flex items-center justify-center mb-2">
                <i class="fas fa-camera text-custom text-xl"></i>
            </div>
            <span class="text-sm font-medium">Media</span>
        </button>
    </div>
    <h2 class="text-xl font-bold mb-4">Popular Courses</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-xl overflow-hidden hover:shadow-md transition-shadow">
            <img src="images/ncr4.jpg"
                style="height: 300px;"
                alt="Python Programming" class="w-full object-cover" />
            <div class="p-4">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-gray-500">12 Weeks</span>
                    <div class="flex items-center">
                        <i class="fas fa-star text-yellow-400"></i>
                        <span class="ml-1 text-sm font-medium">4.8</span>
                    </div>
                </div>
                <h3 class="font-semibold mb-2">Regular Courses</h3>
                <button
                    class="w-full bg-custom text-white py-2 rounded-lg font-medium hover:bg-custom/90 !rounded-button">
                    Send Query
                </button>
            </div>
        </div>
        <div class="bg-white rounded-xl overflow-hidden hover:shadow-md transition-shadow">
            <img src="images/ncr5.jpg"
                style="height: 300px;"
                alt="UI/UX Design" class="w-full object-cover" />
            <div class="p-4">
                <div class="flex items-center justify-between mb-2">
                    <span class="text-sm text-gray-500">4 Weeks</span>
                    <div class="flex items-center">
                        <i class="fas fa-star text-yellow-400"></i>
                        <span class="ml-1 text-sm font-medium">4.9</span>
                    </div>
                </div>
                <h3 class="font-semibold mb-2">Industrial Courses</h3>
                <button
                    class="w-full bg-custom text-white py-2 rounded-lg font-medium hover:bg-custom/90 !rounded-button">
                    Send Query
                </button>
            </div>
        </div>
    </div>
</main>